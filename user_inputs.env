# Env to export

## Basic
export SOURCE_GL_SERVER_URL="http://gitlabpoc.example.com"
export GITLAB_USERNAME="gitlab_user"
export GITLAB_API_PRIVATE_TOKEN="ghp_xxxxxxx"
export GH_PAT="glpat-xxxxxxx"
export STORAGE_TYPE="GITHUB"
export INVENTORY_FILE="gitlab-stats.csv"

 ## For GitHub Enterprise Cloud
export GITHUB_TYPE="GitHub"
export GH_HOST="github.com"

 ## For GitHub Enterprise Cloud with Data Residency
export GITHUB_TYPE="GitHubDR"
export GH_HOST="SUBDOMAIN.ghe.com"

## If STORAGE_TYPE is AZURE
export AZ_CONTAINER=""
export AZURE_STORAGE_CONNECTION_STRING=""

## If STORAGE_TYPE is AWS
export AWS_BUCKET_NAME=""
export AWS_REGION=""
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""


